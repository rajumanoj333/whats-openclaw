# Glue server
PORT=3000
LOG_LEVEL=info

# Evolution API (internal Docker network address)
EVOLUTION_BASE_URL=http://whats-bot_evolution-api:8080
EVOLUTION_API_KEY=replace-with-AUTHENTICATION_API_KEY-from-Evolution
EVOLUTION_INSTANCE=main

# Webhook verification (set the same value in Evolution as WEBHOOK_GLOBAL_SECRET if available)
WEBHOOK_SECRET=

# OpenClaw gateway (reachable from inside this container)
OPENCLAW_GATEWAY_URL=ws://host.docker.internal:18789/ws
OPENCLAW_GATEWAY_TOKEN=replace-with-rotated-gateway-token
OPENCLAW_TIMEOUT_SECONDS=60

# Bot policy
# ALLOWLIST: comma-separated E.164 numbers (with leading +), or "*" for any sender
ALLOWLIST=*
RATE_LIMIT_PER_MIN=30
SKIP_GROUPS=true
SKIP_SELF=true

# UI
PAGE_TITLE=Connect WhatsApp to OpenClaw
